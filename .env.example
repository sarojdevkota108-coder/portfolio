# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://sarojdevkota.com

# ─── Contact form (Resend or Formspree) ──────────────────────────────────────
# Option A — Resend
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL=saroj@example.com

# Option B — Formspree (paste your form endpoint in Contact.tsx)
# NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id

# ─── Sanity CMS (optional — for blog) ────────────────────────────────────────
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# SANITY_API_READ_TOKEN=

# ─── Supabase (optional — for contact form persistence) ──────────────────────
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
